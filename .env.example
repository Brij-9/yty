OPENVIDEO_DATA_DIR=/data
OPENVIDEO_DATABASE=/data/openvideo.db
OPENVIDEO_OUTPUT_DIR=/data/outputs
OPENVIDEO_UPLOAD_DIR=/data/uploads
OPENVIDEO_BACKEND=wan22
OPENVIDEO_WORKER_POLL_SECONDS=2
OPENVIDEO_MAX_ACTIVE_JOBS=1

# Flagship local model. Downloads on first worker run (~34 GB).
OPENVIDEO_WAN_MODEL=Wan-AI/Wan2.2-TI2V-5B-Diffusers
OPENVIDEO_WAN_ENGINE=official
OPENVIDEO_WAN_REPO=/opt/Wan2.2
OPENVIDEO_WAN_CHECKPOINT=/models/Wan2.2-TI2V-5B
OPENVIDEO_DEVICE=cuda
OPENVIDEO_DTYPE=bfloat16
OPENVIDEO_CPU_OFFLOAD=true

# Optional local post-processing executables.
OPENVIDEO_FFMPEG=ffmpeg
OPENVIDEO_FFPROBE=ffprobe
OPENVIDEO_REALESRGAN=
OPENVIDEO_MASTERING=true
OPENVIDEO_TARGET_FPS=30

# Optional self-hosted narration service. No paid API is required.
OPENVIDEO_KOKORO_URL=
OPENVIDEO_KOKORO_VOICE=af_heart
